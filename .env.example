# ============ 通用 ============
NODE_ENV=development
LOG_LEVEL=info

# ============ API ============
API_PORT=3005
API_HOST=0.0.0.0
# 最大文章字数，超过直接 400（SLO 保障：避免长文章导致生成耗时爆炸）
MAX_ARTICLE_CHARS=5000
# 链路 A 成片最长秒数，LLM 脚本超过将被兜底截断
MAX_ARTICLE_VIDEO_SECONDS=90
# 链路 B 成片最长秒数
MAX_ASSETS_VIDEO_SECONDS=120
# 素材库单文件上限（MB）
MAX_MATERIAL_FILE_SIZE_MB=500
# BGM 单文件上限（MB）
MAX_BGM_FILE_SIZE_MB=20
# TTS 预览单次最大字数（防止被当免费 TTS 滥用）
TTS_PREVIEW_MAX_CHARS=200
# /v1/jobs/assets 单次最多文件数
MAX_ASSETS_FILES_PER_UPLOAD=20
# 整个 job 的硬性 deadline（毫秒），超时自动 fail
JOB_TIMEOUT_MS=300000
# Webhook HMAC 签名密钥
WEBHOOK_SIGNING_SECRET=change-me-in-prod
# 开发者凭据（可选，明文）：启动时加入内存 allowlist，便于本地 curl 测试
# 生产环境留空；真实 API Key 由主项目管理后台签发后写入 Redis api_keys 表
DEV_API_KEY=

# ============ Redis / BullMQ ============
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# 各队列的 worker 并发度（见设计文档的并发表）
ARTICLE_CONCURRENCY=10
ASSETS_CONCURRENCY=2
RENDER_CONCURRENCY=1
MIX_CONCURRENCY=2

# ============ S3 兼容对象存储 ============
# 示例：雨云 OSS（https://www.rainyun.com/oss），也可替换为 AWS S3 / 阿里 OSS / Cloudflare R2 等任意 S3 兼容服务
# 注意 endpoint 不带 bucket 前缀；AWS SDK 会按 S3_FORCE_PATH_STYLE 自动拼
S3_ENDPOINT=https://cn-nb1.rains3.com
S3_REGION=rainyun
S3_BUCKET=video
S3_ACCESS_KEY=
S3_SECRET_KEY=
# 虚拟托管风格=false（默认），仅 MinIO/自建需要 true
S3_FORCE_PATH_STYLE=false
# 预签名下载 URL 过期时间（秒），默认 7 天
S3_PRESIGN_EXPIRES=604800

# ============ LLM ============
# 可选: openai | claude | glm | kimi
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=15000

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=

# 智谱 GLM (OpenAI 兼容)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Kimi (OpenAI 兼容)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ============ 硅基流动 SiliconFlow (TTS + Whisper) ============
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
TTS_DEFAULT_VOICE=FunAudioLLM/CosyVoice2-0.5B:alex
STT_MODEL=FunAudioLLM/SenseVoiceSmall
TTS_TIMEOUT_MS=45000
STT_TIMEOUT_MS=30000

# ============ Pexels ============
PEXELS_API_KEY=
PEXELS_TIMEOUT_MS=10000
# 本地素材缓存目录
MEDIA_CACHE_DIR=/tmp/vgs-media-cache
MEDIA_CACHE_MAX_BYTES=21474836480

# ============ 公众号文章提取（第三方同步接口） ============
# 见 docs/WECHAT_ARTICLE_EXTRACT_API.md；服务商 token 只在服务端使用，不透传用户
WECHAT_EXTRACT_API_BASE=https://your-domain.com
WECHAT_EXTRACT_TOKEN=
# 上游 p95 ~8s，这里留足冗余
WECHAT_EXTRACT_TIMEOUT_MS=30000

# ============ Remotion ============
REMOTION_CONCURRENCY=
REMOTION_CODEC=h264
REMOTION_X264_PRESET=veryfast
REMOTION_CRF=23
REMOTION_TIMEOUT_MS=120000

